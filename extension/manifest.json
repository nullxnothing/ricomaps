{
  "manifest_version": 3,
  "name": "RicoMaps — Cabal Map for Axiom",
  "version": "1.0.0",
  "description": "Shows the RicoMaps holder/cabal bubble map inline on axiom.trade token pages.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://axiom.trade/*", "https://ricomaps.fun/*"],
  "content_scripts": [
    {
      "matches": ["https://axiom.trade/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png"],
      "matches": ["https://axiom.trade/*"]
    }
  ]
}
