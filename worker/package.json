{
  "name": "ricomaps-laserstream-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Always-on LaserStream gRPC worker that streams Solana token holder balance deltas to Rico Maps browsers over SSE.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helius-laserstream": "0.3.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
